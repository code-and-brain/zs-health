# ZS Health Platform - Global Environment Config
PLATFORM_ENV=development

# Database Configuration (Using Local Postgres 17.7)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=zs_health

# Services Configuration
LOG_LEVEL=debug
AUTH_SERVICE_PORT=8081
PATIENT_REGISTRY_PORT=8082

# Hardware Constraints Optimization
# System has ~8GB RAM, limit concurrent service builds
MAX_CONCURRENT_BUILDS=2
LAZY_START_ENABLED=true
