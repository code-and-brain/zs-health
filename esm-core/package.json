{
    "name": "@zs-health/esm-core",
    "version": "1.0.0",
    "private": true,
    "description": "ZS Health ESM Core - Framework & Foundation Monorepo",
    "repository": {
        "type": "git",
        "url": "https://github.com/zs-health/esm-core.git"
    },
    "workspaces": [
        "apps/*",
        "packages/*",
        "configs/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=@zs-health/shell",
        "build": "npm run build --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "clean": "rm -rf node_modules */*/node_modules */*/dist",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
    },
    "devDependencies": {
        "@types/node": "^25.0.10",
        "prettier": "^3.4.0",
        "sass": "^1.97.3",
        "typescript": "^5.7.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
