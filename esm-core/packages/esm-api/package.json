{
    "name": "@zs-health/esm-api",
    "version": "1.0.0",
    "private": true,
    "description": "API client utilities for ZS Health applications",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.93.1",
        "@zs-health/esm-config": "*"
    },
    "devDependencies": {
        "@zs-health/eslint-config": "*",
        "@zs-health/typescript-config": "*",
        "typescript": "^5.7.0"
    }
}
